# ═══════════════════════════════════════════════════════════════════
# BIM Hive Marketplace V2 — environment template
# Copy to .env and fill with REAL values. .env is git-ignored; never commit it.
# ═══════════════════════════════════════════════════════════════════

# ── Django core ──
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins allowed to make credentialed API calls in dev.
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ──
# Local dev (docker-compose): postgres://bimhive:bimhive@localhost:5432/bimhive
# Production (Railway): postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://bimhive:bimhive@localhost:5432/bimhive

# ── Cloudflare R2 (S3-compatible object storage) ──
# Local dev uses MinIO (docker-compose). Production uses R2.
R2_BUCKET_NAME=bhmarketplacev2
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=
R2_REGION=auto
# Seconds a signed download URL stays valid.
R2_SIGNED_URL_TTL=300

# ── Licensing (MUST match production or field activations fail) ──
LICENSE_PEPPER=change-me-must-match-production
# Legacy installer-generator DB, used only by the one-time import command.
LEGACY_LICENSE_DATABASE_URL=
# Signs the /api/license/activate response (HMAC) so a tampered plugin
# loader has to forge a signature, not just a boolean. Any long random string.
LICENSE_SIGNING_KEY=change-me-to-a-long-random-string

# ── Auto-generated plugin installers ──
# Name of the WiX v5 CLI on PATH. `dotnet tool install --global wix` installs
# it as `wix`; only change this if your build environment uses a different
# name or an absolute path.
WIX_EXECUTABLE=wix
INSTALLER_BUILD_TIMEOUT_SECONDS=180
INSTALLER_MANUFACTURER=BIMHive

# ── Payments ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=sandbox

# ── Frontend (/web) ──
# Base URL the Next.js server uses to reach the Django API (server-side).
API_INTERNAL_URL=http://localhost:8000
# Public site URL (used for SEO canonical/sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
